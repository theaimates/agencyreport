# ReportFlow — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── n8n ──────────────────────────────────────────────────────────────────────
# Base URL of your self-hosted n8n instance (no trailing slash)
N8N_BASE_URL=https://your-n8n-instance.com

# Optional: shared secret sent as X-Webhook-Secret header
# Leave blank if your n8n webhooks are open (fine for local/portfolio use)
N8N_WEBHOOK_SECRET=

# ─── Airtable ─────────────────────────────────────────────────────────────────
# Your Airtable base ID (starts with app...)
# Used only if running Python tools locally — n8n handles this in production
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_API_KEY=

# ─── Notes ────────────────────────────────────────────────────────────────────
# All other API keys (Google Analytics, Meta, Stripe, Mailchimp, OpenAI)
# are stored as n8n credentials — they never touch this file.
