# ── ReportFlow Dashboard ──────────────────────────────────────────
# Copy this file to .env.local for local dev, or set these as
# environment variables in your Vercel project settings.
#
# These are SERVER-SIDE ONLY — never exposed to the browser.
# ─────────────────────────────────────────────────────────────────

# Your self-hosted n8n instance URL (no trailing slash)
N8N_BASE_URL=https://your-n8n-instance.com

# Webhook secret — must match the secret checked in WF6 node "Compute Date Window"
# Leave empty if your n8n webhooks are open (not recommended for production)
N8N_WEBHOOK_SECRET=your_webhook_secret_here
