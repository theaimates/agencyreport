    {
      "id": "wf1-004",
      "name": "GA4 Run Report",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1000, 100],
      "onError": "continueRegularOutput",
      "parameters": {
        "method": "POST",
        "url": "=https://analyticsdata.googleapis.com/v1beta/properties/{{ $json.ga4_property_id }}:runReport",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleOAuth2Api",
        "sendBody": true,
        "contentType": "json",
        "body": "{\"dateRanges\":[{\"startDate\":\"yesterday\",\"endDate\":\"yesterday\"}],\"dimensions\":[{\"name\":\"date\"},{\"name\":\"sessionDefaultChannelGroup\"}],\"metrics\":[{\"name\":\"totalRevenue\"},{\"name\":\"sessions\"},{\"name\":\"transactions\"},{\"name\":\"conversions\"},{\"name\":\"averageOrderValue\"}]}"
      },
      "credentials": {
        "googleOAuth2Api": {
          "id": "2",
          "name": "Google account"
        }
      }
    },
    {
      "id": "wf1-005",
      "name": "Parse GA4 Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1240, 100],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const rows = $input.all();\nconst data = rows[0].json;\nconst clientItem = $('Get Active Clients').first();\n\nif (!data || data.error || data.code) {\n  return [{ json: { platform: 'ga4', client_id: clientItem.json.client_id, revenue: 0, sessions: 0, transactions: 0, spend: 0, error: true } }];\n}\n\nconst results = [];\n\nif (data.rows) {\n  for (const row of data.rows) {\n    results.push({\n      date: row.dimensionValues[0].value,\n      channel: row.dimensionValues[1].value,\n      revenue: parseFloat(row.metricValues[0].value) || 0,\n      sessions: parseInt(row.metricValues[1].value) || 0,\n      transactions: parseInt(row.metricValues[2].value) || 0,\n      conversions: parseInt(row.metricValues[3].value) || 0,\n      aov: parseFloat(row.metricValues[4].value) || 0,\n      client_id: clientItem.json.client_id,\n      platform: 'ga4',\n      source: 'Google Analytics 4'\n    });\n  }\n}\nreturn results.map(r => ({ json: r }));"
      }
    },
    {
