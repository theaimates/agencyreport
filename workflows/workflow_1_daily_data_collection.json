    {
      "id": "wf1-008",
      "name": "Meta Get Insights",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1480, 320],
      "parameters": {
        "method": "GET",
        "url": "=https://graph.facebook.com/v19.0/{{ $json.id }}/insights",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "fields",
              "value": "impressions,clicks,ctr,spend,cpc,actions,action_values,campaign_id,campaign_name"
            },
            {
              "name": "time_range",
              "value": "={{ JSON.stringify({ since: $now.minus({ days: 1 }).toFormat('yyyy-MM-dd'), until: $now.minus({ days: 1 }).toFormat('yyyy-MM-dd') }) }}"
            },
            {
              "name": "level",
              "value": "campaign"
            }
          ]
        }
      },
      "credentials": {
        "httpBearerAuth": {
          "id": "3",
          "name": "Meta Bearer Token"
        }
      }
    },
    {
      "id": "wf1-009",
      "name": "Parse Meta Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1720, 320],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const insights = $input.all();\nconst clientItem = $('Get Active Clients').first();\nconst first = insights[0]?.json;\n\nif (!first || first.error || first.message) {\n  return [{ json: { platform: 'meta', client: clientItem.json.client_id, impressions: 0, clicks: 0, spend: 0, revenue: 0, conversions: 0, error: true } }];\n}\n\nreturn insights.map(item => {\n  const d = item.json.data?.[0] || item.json;\n  const conversions = d.actions?.find(\n    a => a.action_type === 'purchase'\n  )?.value || 0;\n  const revenue = d.action_values?.find(\n    a => a.action_type === 'purchase'\n  )?.value || 0;\n\n  return {\n    json: {\n      platform: 'meta',\n      campaign_id: d.campaign_id || item.json.id,\n      campaign_name: d.campaign_name || item.json.name,\n      client: clientItem.json.client_id,\n      impressions: parseInt(d.impressions) || 0,\n      clicks: parseInt(d.clicks) || 0,\n      ctr: parseFloat(d.ctr) || 0,\n      spend: parseFloat(d.spend) || 0,\n      cpc: parseFloat(d.cpc) || 0,\n      conversions: parseInt(conversions),\n      revenue: parseFloat(revenue),\n      date: d.date_start || $now.minus({ days: 1 }).toFormat('yyyy-MM-dd'),\n      status: 'Active',\n      source: 'Meta Ads'\n    }\n  };\n});"
      }
    },
    {
      "id": "wf1-010",
      "name": "Google Ads Query",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1000, 540],
      "onError": "continueRegularOutput",
      "parameters": {
        "method": "POST",
        "url": "=https://googleads.googleapis.com/v17/customers/{{ $json.google_ads_customer_id }}/googleAds:searchStream",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleOAuth2Api",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "developer-token",
              "value": "YOUR_GOOGLE_ADS_DEVELOPER_TOKEN"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ query: \"SELECT campaign.id, campaign.name, campaign.status, metrics.impressions, metrics.clicks, metrics.ctr, metrics.cost_micros, metrics.conversions, metrics.conversions_value, metrics.average_cpc FROM campaign WHERE segments.date = '\" + $now.minus({ days: 1 }).toFormat('yyyy-MM-dd') + \"' AND campaign.status IN ('ENABLED', 'PAUSED')\" }) }}"
      },
      "credentials": {
        "googleOAuth2Api": {
          "id": "2",
          "name": "Google account"
        }
      }
    },
    {
      "id": "wf1-011",
      "name": "Parse Google Ads",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1240, 540],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const response = $input.all();\nconst clientItem = $('Get Active Clients').first();\nconst first = response[0]?.json;\n\nif (!first || first.error || (first.status && first.status !== 200)) {\n  return [{ json: { platform: 'google', client: clientItem.json.client_id, impressions: 0, clicks: 0, spend: 0, revenue: 0, conversions: 0, error: true } }];\n}\n\nconst results = [];\n\nfor (const item of response) {\n  for (const result of (item.json.results || [])) {\n    results.push({\n      json: {\n        platform: 'google',\n        campaign_id: result.campaign.id,\n        campaign_name: result.campaign.name,\n        client: clientItem.json.client_id,\n        status: result.campaign.status,\n        impressions: parseInt(result.metrics.impressions) || 0,\n        clicks: parseInt(result.metrics.clicks) || 0,\n        ctr: parseFloat(result.metrics.ctr) || 0,\n        spend: (parseInt(result.metrics.costMicros) || 0) / 1000000,\n        cpc: (parseInt(result.metrics.averageCpc) || 0) / 1000000,\n        conversions: parseFloat(result.metrics.conversions) || 0,\n        revenue: parseFloat(result.metrics.conversionsValue) || 0,\n        date: $now.minus({ days: 1 }).toFormat('yyyy-MM-dd'),\n        source: 'Google Ads'\n      }\n    });\n  }\n}\nreturn results;"
      }
    },
    {
      "id": "wf1-012",
      "name": "Stripe Get Charges",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1000, 760],
      "onError": "continueRegularOutput",
      "parameters": {
        "method": "GET",
        "url": "https://api.stripe.com/v1/charges",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "created[gte]",
              "value": "={{ $now.startOf('day').minus({ days: 1 }).toUnixInteger() }}"
            },
            {
              "name": "created[lt]",
              "value": "={{ $now.startOf('day').toUnixInteger() }}"
            },
            {
              "name": "limit",
              "value": "100"
            },
            {
              "name": "status",
              "value": "succeeded"
            }
          ]
        }
      },
      "credentials": {
        "httpBearerAuth": {
          "id": "4",
          "name": "Stripe API Key"
        }
      }
    },
    {
      "id": "wf1-012b",
      "name": "Collect Stripe Page",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1240, 760],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const response = $input.first().json;\nconst prev = response._accumulated || [];\nconst page = (response._page || 0) + 1;\n\nif (!response || response.error) {\n  return [{ json: { _accumulated: prev, has_more: false, last_id: null, _page: page } }];\n}\n\nconst pageCharges = response.data || [];\nconst accumulated = [...prev, ...pageCharges];\nconst lastId = pageCharges[pageCharges.length - 1]?.id || null;\n// Safety: cap at 10 pages (1,000 charges) to prevent infinite loops\nconst hasMore = page < 10 ? (response.has_more || false) : false;\n\nreturn [{ json: { _accumulated: accumulated, has_more: hasMore, last_id: lastId, _page: page } }];"
      }
    },
    {
      "id": "wf1-012c",
      "name": "More Stripe Pages?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1460, 760],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "leftValue": "={{ $json.has_more }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equal" }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "wf1-012d",
      "name": "Stripe Next Page",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1680, 680],
      "onError": "continueRegularOutput",
      "parameters": {
        "method": "GET",
        "url": "https://api.stripe.com/v1/charges",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "created[gte]", "value": "={{ $now.startOf('day').minus({ days: 1 }).toUnixInteger() }}" },
            { "name": "created[lt]",  "value": "={{ $now.startOf('day').toUnixInteger() }}" },
            { "name": "limit",         "value": "100" },
            { "name": "status",        "value": "succeeded" },
            { "name": "starting_after","value": "={{ $json.last_id }}" }
          ]
        }
      },
      "credentials": {
        "httpBearerAuth": { "id": "4", "name": "Stripe API Key" }
      }
    },
    {
      "id": "wf1-013",
      "name": "Aggregate Stripe Revenue",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1680, 840],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const item = $input.first().json;\nconst charges = item._accumulated || [];\nconst clientItem = $('Get Active Clients').first();\n\nlet totalRevenue = 0;\nlet totalOrders = 0;\n\nfor (const c of charges) {\n  totalRevenue += (c.amount || 0) / 100;\n  totalOrders += 1;\n}\n\nreturn [{\n  json: {\n    date: $now.minus({ days: 1 }).toFormat('yyyy-MM-dd'),\n    total_revenue: parseFloat(totalRevenue.toFixed(2)),\n    total_orders: totalOrders,\n    avg_order_value: totalOrders > 0 ? parseFloat((totalRevenue / totalOrders).toFixed(2)) : 0,\n    client_id: clientItem.json.client_id,\n    client: clientItem.json.client_id,\n    platform: 'stripe',\n    source: 'Stripe',\n    channel: 'Direct / Revenue',\n    revenue: parseFloat(totalRevenue.toFixed(2)),\n    transactions: totalOrders,\n    spend: 0\n  }\n}];"
      }
    },
    {
      "id": "wf1-014",
      "name": "Mailchimp Get Reports",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1000, 980],
      "onError": "continueRegularOutput",
      "parameters": {
        "method": "GET",
        "url": "=https://{{ $('Split In Batches').first().json.mailchimp_dc || 'us1' }}.api.mailchimp.com/3.0/reports",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "count",
              "value": "10"
            },
            {
              "name": "since_send_time",
              "value": "={{ $now.minus({ days: 1 }).toFormat('yyyy-MM-dd') }}"
            }
          ]
        }
      },
      "credentials": {
        "httpBasicAuth": {
          "id": "5",
          "name": "Mailchimp Basic Auth"
        }
      }
    },
    {
      "id": "wf1-015",
      "name": "Parse Email Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1240, 980],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const response = $input.all();\nconst clientItem = $('Get Active Clients').first();\nconst first = response[0]?.json;\n\nif (!first || first.error || first.status === 401 || first.status === 403) {\n  return [{ json: { platform: 'email', client: clientItem.json.client_id, impressions: 0, clicks: 0, revenue: 0, conversions: 0, spend: 0, date: $now.minus({ days: 1 }).toFormat('yyyy-MM-dd'), error: true } }];\n}\n\nconst allReports = [];\n\nfor (const item of response) {\n  const reports = item.json.reports || [item.json];\n  for (const r of reports) {\n    if (!r.id) continue;\n    allReports.push({\n      json: {\n        platform: 'email',\n        campaign_id: r.id,\n        campaign_name: r.settings?.subject_line || 'Email Campaign',\n        client: clientItem.json.client_id,\n        impressions: r.emails_sent || 0,\n        opens: r.opens?.unique_opens || 0,\n        clicks: r.clicks?.unique_clicks || 0,\n        ctr: r.clicks?.click_rate || 0,\n        spend: 0,\n        revenue: r.ecommerce?.total_revenue || 0,\n        conversions: r.ecommerce?.total_orders || 0,\n        date: $now.minus({ days: 1 }).toFormat('yyyy-MM-dd'),\n        source: 'Mailchimp'\n      }\n    });\n  }\n}\nreturn allReports.length > 0 ? allReports : [{ json: { platform: 'email', client: clientItem.json.client_id, impressions: 0, clicks: 0, revenue: 0, conversions: 0, spend: 0, date: $now.minus({ days: 1 }).toFormat('yyyy-MM-dd') } }];"
      }
    },
