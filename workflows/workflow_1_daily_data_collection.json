    {
      "id": "wf1-018",
      "name": "Create Revenue Record",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [2480, 500],
      "parameters": {
        "operation": "create",
        "base": {
          "value": "YOUR_AIRTABLE_BASE_ID",
          "mode": "id"
        },
        "table": {
          "value": "Revenue",
          "mode": "name"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "client": "={{ $json.client || $json.client_id }}",
            "week_label": "={{ $now.minus({ days: 1 }).toFormat('yyyy-MM-dd') }}",
            "week_start": "={{ $now.minus({ days: 1 }).toFormat('yyyy-MM-dd') }}",
            "channel": "={{ $json.channel || $json.platform }}",
            "revenue": "={{ $json.revenue || $json.total_revenue || 0 }}",
            "transactions": "={{ $json.transactions || $json.conversions || $json.total_orders || 0 }}",
            "source": "={{ $json.source || $json.platform }}"
          },
          "matchingColumns": [],
          "schema": []
        },
        "options": {}
      },
      "credentials": {
        "airtableTokenApi": {
          "id": "1",
          "name": "Airtable account"
        }
      }
    },
    {
      "id": "wf1-019",
      "name": "Aggregate KPI Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2720, 500],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const allData = $input.all();\nlet totalRevenue = 0, totalSpend = 0,\n    totalSessions = 0, totalOrders = 0;\nconst clientItem = $('Get Active Clients').first();\n\nfor (const item of allData) {\n  totalRevenue += item.json.revenue || item.json.total_revenue || 0;\n  totalSpend += item.json.spend || 0;\n  totalSessions += item.json.sessions || 0;\n  totalOrders += item.json.conversions || item.json.transactions || item.json.total_orders || 0;\n}\n\nconst convRate = totalSessions > 0\n  ? (totalOrders / totalSessions) * 100 : 0;\nconst roas = totalSpend > 0\n  ? totalRevenue / totalSpend : 0;\nconst aov = totalOrders > 0\n  ? totalRevenue / totalOrders : 0;\n\nreturn [{\n  json: {\n    client: clientItem.json.client_id,\n    snapshot_date: $now.minus({ days: 1 }).toFormat('yyyy-MM-dd'),\n    period_type: 'Daily',\n    total_revenue: parseFloat(totalRevenue.toFixed(2)),\n    ad_spend: parseFloat(totalSpend.toFixed(2)),\n    roas: parseFloat(roas.toFixed(2)),\n    conversion_rate: parseFloat(convRate.toFixed(2)),\n    total_orders: totalOrders,\n    total_sessions: totalSessions,\n    avg_order_value: parseFloat(aov.toFixed(2))\n  }\n}];"
      }
    },
